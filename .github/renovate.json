{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>SonarSource/core-languages-tooling-public:languages-tooling"
  ],
  "enabledManagers": [
    "github-actions",
    "maven"
  ],
  "dockerfile": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": false
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "pin",
        "rollback"
      ],
      "enabled": false
    }
  ]
}
